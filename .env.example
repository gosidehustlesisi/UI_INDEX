# UI_INDEX Environment Variables
# Copy this file to .env and fill in your real API keys
# DO NOT commit .env to git — it is already in .gitignore

# FEC API Key — Required for FEC funding data
# Get your key at: https://api.open.fec.gov/developers/
FEC_API_KEY=your_fec_api_key_here

# Census API Key — Required for median income data
# Get your key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# Congress.gov uses DEMO_KEY for public access (no key needed for basic use)
# For higher rate limits, apply at: https://api.congress.gov/
